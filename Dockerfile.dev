# ── Development Only ─────────────────────────────────────────────────────────
# Dùng cho local development với Hot Module Replacement (HMR)
FROM node:22-alpine

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci --frozen-lockfile

# Source code được mount qua volume trong docker-compose
# nên không COPY . . ở đây

EXPOSE 5173

# --host 0.0.0.0: cho phép truy cập từ ngoài container
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
